# ─── Database (NeonDB — serverless Postgres) ──────────────
# Neon Dashboard → Project → Connection Details.
# DATABASE_URL = POOLED string (host ends in "-pooler"); DIRECT_URL = direct.
# Both require ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# ─── GOAT Network ─────────────────────────────────────────
# Testnet3: chainId 48816 · Mainnet: chainId 2345 · gas token: BTC
GOAT_NETWORK=testnet
GOAT_RPC_URL=https://rpc.testnet3.goat.network

# NEXT_PUBLIC_ variants required for client-side code (contracts.ts / launch page)
NEXT_PUBLIC_GOAT_NETWORK=testnet
NEXT_PUBLIC_GOAT_RPC_URL=https://rpc.testnet3.goat.network
NEXT_PUBLIC_GOAT_CHAIN_ID=48816
NEXT_PUBLIC_GOAT_EXPLORER_URL=https://explorer.testnet3.goat.network

# ─── GOAT Operator (server-side signing / treasury) ──────
# A funded EVM private key (0x...). Fund via the GOAT testnet faucet.
GOAT_OPERATOR_PRIVATE_KEY=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GOAT_OPERATOR_ADDRESS=0x...   # optional; derived from the key if unset

# ─── Talos Solidity Contracts (from contracts/ deploy) ───
# Run: cd contracts && pnpm deploy:testnet (prints these addresses)
NEXT_PUBLIC_TALOS_REGISTRY_ADDRESS=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_TALOS_NAME_SERVICE_ADDRESS=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_PULSE_TOKEN_FACTORY_ADDRESS=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Payment token ────────────────────────────────────────
# GOAT has NO native USDC. Its canonical ERC-20 is WGBTC
# (0xBC10000000000000000000000000000000000000, 18 decimals), used by default.
# To price services in a bridged USDC instead, set these:
# GOAT_USDC_ADDRESS=0x...
# GOAT_USDC_DECIMALS=6
# NEXT_PUBLIC_PAYMENT_TOKEN_ADDRESS=0x...   # client-side payment token (else native BTC)

# ─── Wallet Connection (RainbowKit / WalletConnect) ──────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# NEXT_PUBLIC_TALOS_OPERATOR_ADDRESS=0x...  # treasury/payment recipient shown in UI

# ─── x402 on GOAT (hosted merchant API) ──────────────────
# AgentKit's GoatAdapter talks to https://api.goatx402.com.
# Without API key/secret, the server falls back to a direct ERC-20 transfer (dev mode).
GOAT_X402_BASE_URL=https://api.goatx402.com
GOAT_X402_API_KEY=
GOAT_X402_API_SECRET=

# ─── ERC-8004 identity (canonical, auto-selected per network) ──
# Testnet3 Identity Registry:  0x556089008Fc0a60cD09390Eca93477ca254A5522
# Mainnet  Identity Registry:  0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
# (wired in src/lib/goat-chain.ts; override only if GOAT changes them)

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

# ─── Talos Genesis ────────────────────────────────────────
# Gas for Genesis is paid in BTC on GOAT.
