# ─── GOAT Network deploy config ───────────────────────────────────────
# Confirm canonical values in docs.goat.network before mainnet use.

# Testnet (AgentKit references chainId 48816 "Testnet3")
GOAT_TESTNET_RPC=https://rpc.testnet3.goat.network
GOAT_TESTNET_CHAIN_ID=48816

# Mainnet
GOAT_MAINNET_RPC=https://rpc.goat.network
GOAT_MAINNET_CHAIN_ID=2345

# Deployer key (funded with testnet BTC from the GOAT faucet, 0.01 BTC/day)
DEPLOYER_PRIVATE_KEY=

# Protocol wallet that receives the 3% launchpad fee (defaults to deployer)
PROTOCOL_WALLET=

# ─── Post-Deployment (auto-printed by scripts/deploy.ts) ──────────────
# Copy these to web/.env.local:
# NEXT_PUBLIC_TALOS_REGISTRY_ADDRESS=0x...
# NEXT_PUBLIC_TALOS_NAME_SERVICE_ADDRESS=0x...
# NEXT_PUBLIC_PULSE_TOKEN_FACTORY_ADDRESS=0x...
